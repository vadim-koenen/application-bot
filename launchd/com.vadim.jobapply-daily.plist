<?xml version="1.0" encoding="UTF-8"?>
<!--
  Daily discovery. Each morning at 08:00 it runs a live last-24h scan so the app
  opens populated with fresh in-lane roles. It does NOT email or submit anything;
  you review + apply in the app.

  Install (edit the paths below to your checkout first if different):
    cp launchd/com.vadim.jobapply-daily.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.vadim.jobapply-daily.plist
  Uninstall:
    launchctl bootout gui/$(id -u)/com.vadim.jobapply-daily
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.vadim.jobapply-daily</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/vadimkoenen/Documents/Application Agent/app_main.py</string>
    <string>--auto</string>
    <string>--hours</string>
    <string>72</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/vadimkoenen/Documents/Application Agent</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/jobapply-daily.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/jobapply-daily.log</string>
</dict>
</plist>
